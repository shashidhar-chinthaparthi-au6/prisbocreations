MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/prisbocreations?retryWrites=true&w=majority
JWT_SECRET=change-me-to-a-long-random-string
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Optional: S3 presigned uploads (admin). Must match NEXT_PUBLIC_S3_PUBLIC_URL host users load images from.
# IAM policy needs: s3:PutObject, s3:DeleteObject, s3:GetObject on arn:aws:s3:::YOUR_BUCKET/uploads/*
# (Buyer reference images use uploads/customer-uploads/* under that same prefix.)
# Videos use the same prefix; max ~100 MB per file (admin catalog images max 5 MB).
# Buyer reference images allow up to 30 MB — see src/lib/media-upload.ts.
# (GetObject is used by /api/v1/admin/s3/inline for thumbnails when objects are private.)
# For the public storefront, also add an S3 bucket policy allowing s3:GetObject on uploads/* for Principal "*".
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=your-bucket
# S3_PUBLIC_BASE_URL=https://your-cdn.example.com
# NEXT_PUBLIC_S3_PUBLIC_URL=https://your-cdn.example.com

# Optional: Shiprocket (https://www.shiprocket.in/) — pickup, delivery, AWB, tracking.
# Auth: API user email + password from Settings → API, OR paste JWT from POST .../v1/external/auth/login as:
# SHIPROCKET_BEARER_TOKEN=eyJ...  (TSP “API key” / random base64 is not a valid Bearer for External API.)
# Pickup location name must match Shiprocket → Settings → Pickup addresses (exact title).
# SHIPROCKET_EMAIL=
# SHIPROCKET_PASSWORD=
# SHIPROCKET_BEARER_TOKEN=
# SHIPROCKET_PICKUP_LOCATION=Primary Warehouse
# SHIPROCKET_PICKUP_PINCODE=110001
# SHIPROCKET_DEFAULT_WEIGHT_KG=0.5
# SHIPROCKET_DEFAULT_LENGTH_CM=20
# SHIPROCKET_DEFAULT_BREADTH_CM=15
# SHIPROCKET_DEFAULT_HEIGHT_CM=5
# Shipment webhooks (Settings → Additional settings → Webhooks). POST URL must NOT contain the words
# shiprocket, kartrocket, sr, or kr (Shiprocket rule). Use your public site, e.g.:
#   https://YOUR_DOMAIN/api/v1/webhooks/courier-tracking
# Same random string in panel “Token” and here; Shiprocket sends it as header x-api-key.
# SHIPROCKET_WEBHOOK_SECRET=generate-a-long-random-string

# --- Email (Amazon SES) & SMS (Msg91) — transactional notifications ---
# SES: verify SES_FROM_EMAIL (or domain) in SES console; same AWS creds/region as S3 or IAM role on host.
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# SES_FROM_EMAIL=noreply@yourdomain.com
# SES_FROM_NAME=Prisbo Creations
#
# Msg91 Flow API (https://control.msg91.com/) — create Flow templates; map VAR1, VAR2… to your template.
# MSG91_AUTHKEY=
# Optional per-event template IDs (SMS skipped if unset):
# MSG91_TEMPLATE_ORDER_PLACED=
# MSG91_TEMPLATE_ORDER_PAID=
# MSG91_TEMPLATE_ORDER_CANCELLED=
# MSG91_TEMPLATE_ORDER_SHIPPED=
# MSG91_SHORT_URL_DEFAULT=0
