MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/prisbocreations?retryWrites=true&w=majority
JWT_SECRET=change-me-to-a-long-random-string
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Optional: S3 presigned uploads (admin). Must match NEXT_PUBLIC_S3_PUBLIC_URL host users load images from.
# IAM policy needs: s3:PutObject, s3:DeleteObject, s3:GetObject on arn:aws:s3:::YOUR_BUCKET/uploads/*
# Videos use the same prefix; max ~100 MB per file (images max 5 MB).
# (GetObject is used by /api/v1/admin/s3/inline for thumbnails when objects are private.)
# For the public storefront, also add an S3 bucket policy allowing s3:GetObject on uploads/* for Principal "*".
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=your-bucket
# S3_PUBLIC_BASE_URL=https://your-cdn.example.com
# NEXT_PUBLIC_S3_PUBLIC_URL=https://your-cdn.example.com
